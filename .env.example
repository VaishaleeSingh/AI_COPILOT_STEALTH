# Assistant API Keys
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ASSEMBLY_API_KEY=your_assemblyai_api_key_here
GROQ_API_KEY=your_groq_api_key_here
RAPID_API_KEY=your_rapidapi_onecompiler_key_here

# OpenRouter (optional — if set, used as primary LLM instead of Groq)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_MODEL=deepseek/deepseek-r1

# Anthropic Claude API (highest priority if set)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Custom OpenAI-compatible provider (second priority if CUSTOM_LLM_BASE_URL is set)
CUSTOM_LLM_BASE_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_LLM_MODEL=
CUSTOM_LLM_HEADER_NAME=
CUSTOM_LLM_HEADER_VALUE=
